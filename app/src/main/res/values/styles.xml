<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== BUTTONS ===== -->

    <style name="BtnPrimary" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/btn_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/brand_indigo</item>
        <item name="cornerRadius">@dimen/btn_radius</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="BtnAccent" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/btn_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/accent_teal</item>
        <item name="cornerRadius">@dimen/btn_radius</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="BtnOutline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/btn_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textColor">@color/brand_indigo</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="strokeColor">@color/brand_indigo</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">@dimen/btn_radius</item>
        <item name="backgroundTint">@color/transparent</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="BtnDangerOutline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/btn_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textColor">@color/status_error</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="strokeColor">@color/status_error</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">@dimen/btn_radius</item>
        <item name="backgroundTint">@color/transparent</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ===== INPUT FIELDS ===== -->

    <style name="InputFilled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_radius</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/brand_indigo</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- ===== CARDS ===== -->

    <style name="CardDefault" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation_small</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="CardSmall" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius_small</item>
        <item name="cardElevation">@dimen/card_elevation_small</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeWidth">0dp</item>
    </style>

</resources>
