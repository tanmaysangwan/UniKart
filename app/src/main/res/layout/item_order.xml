<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title + Type badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvOrderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Product Title"
                android:textSize="15sp"
                android:textColor="@color/text_heading"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvOrderType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUY"
                android:textSize="10sp"
                android:textColor="@color/badge_buy_text"
                android:background="@drawable/bg_badge_sale"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Requested"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="6dp"/>

        <!-- Price + Date row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvOrderPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₹ 500"
                android:textSize="15sp"
                android:textColor="@color/brand_indigo"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 Jan 2025"
                android:textSize="12sp"
                android:textColor="@color/text_hint"/>

        </LinearLayout>

        <!-- Other party -->
        <TextView
            android:id="@+id/tvOtherParty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seller: Campus Store"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>

        <!-- Action button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOrderAction"
            style="@style/BtnPrimary"
            android:layout_height="40dp"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
