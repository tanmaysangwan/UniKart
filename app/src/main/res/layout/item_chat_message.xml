<?xml version="1.0" encoding="utf-8"?>
<!-- WhatsApp-style message bubble: time is INSIDE the bubble, bottom-right -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- bubbleContainer gravity is set in code (START for received, END for sent) -->
    <LinearLayout
        android:id="@+id/bubbleContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start">

        <!-- The bubble itself — maxWidth capped at 75% via code -->
        <LinearLayout
            android:id="@+id/bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_chat_bubble_received"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="7dp"
            android:paddingBottom="5dp">

            <!-- Message text -->
            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2"
                android:textColor="@color/text_heading"/>

            <!-- Time — right-aligned inside bubble, like WhatsApp -->
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:textSize="10.5sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"
                android:layout_marginStart="24dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
