<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== IMAGE HERO ===== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="@drawable/bg_gradient_navy">

                <!-- Product Image -->
                <ImageView
                    android:id="@+id/ivProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/bg_surface"
                    android:scaleType="centerCrop"
                    android:contentDescription="Product Image"/>

                <!-- Back button -->
                <FrameLayout
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_card_white"
                    android:layout_marginTop="48dp"
                    android:layout_marginStart="@dimen/screen_padding"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:contentDescription="Back"/>

                </FrameLayout>

                <!-- Badge -->
                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/badge_buy"
                    android:textSize="@dimen/text_label"
                    android:textColor="@color/badge_buy_text"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:background="@drawable/bg_badge_sale"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginTop="48dp"
                    android:layout_marginEnd="@dimen/screen_padding"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ===== DETAIL CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-24dp"
                app:cardCornerRadius="@dimen/card_radius_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/screen_padding"
                    android:paddingEnd="@dimen/screen_padding"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp">

                    <!-- Title row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvProductTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Product Name"
                            android:textSize="@dimen/text_h2"
                            android:textColor="@color/text_heading"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingMultiplier="1.2"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/tvPrice"/>

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹500"
                            android:textSize="@dimen/text_h2"
                            android:textColor="@color/brand_indigo"
                            android:fontFamily="sans-serif-medium"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Category + Rent info row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvCategory"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"/>

                        <TextView
                            android:id="@+id/tvMaxRentDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">

                        <View
                            android:id="@+id/ivSellerAvatar"
                            android:layout_width="@dimen/avatar_size_sm"
                            android:layout_height="@dimen/avatar_size_sm"
                            android:background="@drawable/bg_avatar_placeholder"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/tvSellerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Seller Name"
                                android:textSize="@dimen/text_body"
                                android:textColor="@color/text_heading"
                                android:fontFamily="sans-serif-medium"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="2dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_seller"
                                    android:textSize="@dimen/text_caption"
                                    android:textColor="@color/text_secondary"/>

                                <TextView
                                    android:id="@+id/tvSellerRating"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⭐ 4.8 (23)"
                                    android:textSize="@dimen/text_caption"
                                    android:textColor="@color/text_secondary"
                                    android:fontFamily="sans-serif-medium"
                                    android:visibility="gone"
                                    android:layout_marginStart="8dp"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Verified chip -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ Verified"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_white"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/bg_verified_badge"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Description -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_description"
                        android:textSize="@dimen/text_h3"
                        android:textColor="@color/text_heading"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Product description will appear here. This is a placeholder for the full product details that will be loaded from the backend."
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_body"
                        android:lineSpacingMultiplier="1.6"/>

                    <!-- ===== REVIEWS SECTION ===== -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Reviews header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reviews"
                            android:textSize="@dimen/text_h3"
                            android:textColor="@color/text_heading"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvReviewCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <!-- Reviews list (non-scrolling, embedded in scroll view) -->
                    <LinearLayout
                        android:id="@+id/llReviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <!-- No reviews state -->
                    <TextView
                        android:id="@+id/tvNoReviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No reviews yet for this product"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM ACTION BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/bg_white"
        android:elevation="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChat"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/btn_chat_seller"
            android:textSize="15sp"
            android:textColor="@color/brand_indigo"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            app:strokeColor="@color/brand_indigo"
            app:strokeWidth="1.5dp"
            app:cornerRadius="14dp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRequest"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/btn_request"
            android:textSize="15sp"
            android:textColor="@color/text_white"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/brand_indigo"
            app:cornerRadius="14dp"
            android:layout_marginStart="8dp"/>

        <!-- Edit Button (shown only for owner) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Edit Listing"
            android:textSize="15sp"
            android:textColor="@color/text_white"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/brand_indigo"
            app:cornerRadius="14dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="@color/text_white"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
