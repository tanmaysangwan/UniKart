<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== PROFILE HERO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_navy"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp"
                android:fitsSystemWindows="true">

                <!-- Page Title -->
                <TextView
                    android:id="@+id/tvPageTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_title"
                    android:textSize="22sp"
                    android:textColor="@color/text_white"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="16dp"/>

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/ivProfileAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_avatar_placeholder"
                    android:scaleType="centerCrop"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Profile Picture"
                    android:layout_marginTop="24dp"
                    android:layout_marginStart="16dp"/>

                <!-- Name -->
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_name"
                    android:textSize="22sp"
                    android:textColor="@color/text_white"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"/>

                <!-- University -->
                <TextView
                    android:id="@+id/tvUniversity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_university"
                    android:textSize="13sp"
                    android:textColor="#99FFFFFF"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"/>

                <!-- Student ID -->
                <TextView
                    android:id="@+id/tvStudentId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ID: 12345"
                    android:textSize="13sp"
                    android:textColor="#99FFFFFF"
                    android:layout_marginTop="2dp"
                    android:layout_marginStart="16dp"/>

                <!-- Verified badge -->
                <TextView
                    android:id="@+id/tvVerifiedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓  University Verified"
                    android:textSize="12sp"
                    android:textColor="@color/text_white"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_verified_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="16dp"/>

            </LinearLayout>

            <!-- ===== STATS ROW ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- Bought stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvBoughtCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textColor="@color/brand_indigo"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bought"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/divider"/>

                    <!-- Sold stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvSoldCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textColor="@color/brand_indigo"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sold"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/divider"/>

                    <!-- Rating stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="24sp"
                            android:textColor="@color/brand_indigo"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rating"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== MENU ITEMS ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Edit Profile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/bg_white"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_container">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_edit"
                                android:contentDescription="Edit Profile"
                                android:tint="@color/brand_indigo"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Edit Profile"
                            android:textSize="15sp"
                            android:textColor="@color/text_heading"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_more"
                            android:contentDescription="Go"
                            android:tint="@color/text_hint"
                            android:rotation="270"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- My Listings -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMyListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/bg_white"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_container">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_view"
                                android:tint="@color/brand_indigo"
                                android:contentDescription="My Listings"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_my_listings"
                            android:textSize="15sp"
                            android:textColor="@color/text_heading"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_more"
                            android:rotation="270"
                            android:tint="@color/text_hint"
                            android:contentDescription="Arrow"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Reviews -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnReviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/bg_white"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_container">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_myplaces"
                                android:tint="@color/brand_indigo"
                                android:contentDescription="Reviews"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_reviews"
                            android:textSize="15sp"
                            android:textColor="@color/text_heading"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_more"
                            android:rotation="270"
                            android:tint="@color/text_hint"
                            android:contentDescription="Arrow"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Logout -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_logout"
                    android:textSize="15sp"
                    android:textColor="@color/status_error"
                    app:strokeColor="@color/status_error"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_navigation_menu"
        android:elevation="16dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
